---
import {
  AI_DISCLOSURE_LINE,
  FOOTER_LINKS,
  NAV_LINKS,
  SITE_NAME,
  SITE_SUFFIX,
  TAGLINE,
} from '@/data/site';
import { withBase } from '@/utils/url';

const browseLinks = NAV_LINKS;
const aboutLinks = FOOTER_LINKS;
const resourceLinks = [
  { label: '搜尋', href: withBase('/zh/search/') },
  { label: 'RSS', href: withBase('/rss.xml') },
];
const disclosureHref = withBase('/zh/disclosure/');

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__top">
      <div class="footer__brand">
        <div class="footer__logo">
          <span class="footer__logo-zh">{SITE_NAME}</span>
          <span class="footer__logo-url">{SITE_SUFFIX}</span>
        </div>
        <p class="footer__tagline">{TAGLINE}</p>
      </div>

      <div class="footer__columns">
        <div class="footer__col">
          <h2 class="footer__col-title">瀏覽</h2>
          <ul>
            {browseLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer__col">
          <h2 class="footer__col-title">資源</h2>
          <ul>
            {resourceLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer__col">
          <h2 class="footer__col-title">關於</h2>
          <ul>
            {aboutLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__disclosure">
        {AI_DISCLOSURE_LINE}（詳見 <a href={disclosureHref}>AI 生成揭露</a>）
      </p>
      <p class="footer__copyright">
        &copy; {year} {SITE_NAME}　{SITE_SUFFIX}
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-navy);
    padding: var(--space-section-gap) 0 2rem;
    margin-top: var(--space-section-gap);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .footer__top {
      grid-template-columns: 1fr 2fr;
      gap: 3rem;
    }
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__logo {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .footer__logo-zh {
    font-family: var(--font-serif);
    font-size: var(--text-h3);
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-on-dark-heading);
  }

  .footer__logo-url {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--color-on-dark-meta);
  }

  .footer__tagline {
    font-family: var(--font-sans);
    font-size: var(--text-meta);
    color: var(--color-on-dark-body);
    line-height: 1.7;
    max-width: 34ch;
  }

  .footer__columns {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .footer__columns {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .footer__col-title {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    font-weight: 700;
    color: var(--color-on-dark-heading);
    margin-bottom: 0.75rem;
  }

  .footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .footer__col a {
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    color: var(--color-on-dark-body);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer__col a:hover {
    color: var(--color-on-dark-link);
  }

  .footer__bottom {
    border-top: 1px solid color-mix(in oklch, var(--color-on-dark-meta) 20%, transparent);
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__disclosure {
    font-family: var(--font-sans);
    font-size: var(--text-badge);
    color: var(--color-on-dark-meta);
    line-height: 1.7;
  }

  .footer__disclosure a {
    color: var(--color-on-dark-link);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .footer__copyright {
    font-family: var(--font-ui);
    font-size: var(--text-badge);
    color: var(--color-on-dark-meta);
  }
</style>
