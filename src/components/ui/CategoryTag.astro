---
import { ARTICLE_CATEGORIES, type ArticleCategorySlug } from '@/utils/article-categories';

interface Props {
  category: ArticleCategorySlug;
  class?: string;
}

const { category, class: className } = Astro.props;

const meta = ARTICLE_CATEGORIES.find((c) => c.slug === category);
const label = meta?.label ?? category;
const classes = `cat-tag cat-tag--${category}${className ? ` ${className}` : ''}`;
---

<span class={classes}>{label}</span>

<style>
  .cat-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.7rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.4;
    white-space: nowrap;
  }

  .cat-tag--coming-of-age {
    background-color: color-mix(in oklch, var(--color-topic-coming-of-age) 12%, var(--color-paper));
    color: var(--color-topic-coming-of-age);
  }

  .cat-tag--living-together {
    background-color: color-mix(in oklch, var(--color-topic-living-together) 12%, var(--color-paper));
    color: var(--color-topic-living-together);
  }

  .cat-tag--eldercare {
    background-color: color-mix(in oklch, var(--color-topic-eldercare) 12%, var(--color-paper));
    color: var(--color-topic-eldercare);
  }

  .cat-tag--union {
    background-color: color-mix(in oklch, var(--color-topic-union) 12%, var(--color-paper));
    color: var(--color-topic-union);
  }

  .cat-tag--farewell {
    background-color: color-mix(in oklch, var(--color-topic-farewell) 12%, var(--color-paper));
    color: var(--color-topic-farewell);
  }

  .cat-tag--birth {
    background-color: color-mix(in oklch, var(--color-topic-birth) 12%, var(--color-paper));
    color: var(--color-topic-birth);
  }

  .cat-tag--leaving-home {
    background-color: color-mix(in oklch, var(--color-topic-leaving-home) 12%, var(--color-paper));
    color: var(--color-topic-leaving-home);
  }
</style>
