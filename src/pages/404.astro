---
import Base from '@/layouts/Base.astro';
import SearchBar from '@/components/ui/SearchBar.astro';
import Button from '@/components/ui/Button.astro';
import { getPublishedArticles, stripExt } from '@/utils/articles';
import { SITE_NAME } from '@/data/site';
import { withBase } from '@/utils/url';

const latestArticles = (await getPublishedArticles()).slice(0, 3);
---

<Base title={`找不到頁面｜${SITE_NAME}`} noindex={true} lang="zh">
  <div class="not-found container">
    <div class="not-found__content">
      <h1>找不到這個頁面</h1>
      <p class="not-found__subtitle">你要找的頁面可能已被移動或不存在。</p>
      <SearchBar class="not-found__search" />
    </div>

    {latestArticles.length > 0 && (
      <section class="not-found__recommend" aria-label="推薦內容">
        <h2 class="not-found__section-title">推薦內容</h2>
        <ul class="not-found__list">
          {latestArticles.map((entry) => (
            <li>
              <a href={withBase(`/zh/articles/${stripExt(entry.id)}/`)}>{entry.data.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <nav class="not-found__nav" aria-label="主要入口">
      <Button variant="secondary" href={withBase('/zh/')}>回首頁</Button>
      <Button variant="secondary" href={withBase('/zh/articles/')}>文章</Button>
      <Button variant="secondary" href={withBase('/zh/about/')}>關於</Button>
    </nav>
  </div>
</Base>

<style>
  .not-found {
    padding-block: var(--space-page-y);
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .not-found__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    padding-block: 2rem;
  }

  .not-found__content h1 {
    font-family: var(--font-sans);
    font-size: var(--text-h1);
    font-weight: 700;
    color: var(--color-ink);
  }

  .not-found__subtitle {
    font-size: var(--text-body);
    color: color-mix(in oklch, var(--color-ink) 70%, transparent);
    line-height: 1.7;
  }

  .not-found :global(.not-found__search) {
    margin-top: 0.5rem;
  }

  .not-found__recommend {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 52rem;
    margin-inline: auto;
    width: 100%;
  }

  .not-found__section-title {
    font-family: var(--font-sans);
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--color-ink);
  }

  .not-found__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .not-found__list a {
    font-family: var(--font-serif);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-navy);
    text-decoration: none;
  }

  .not-found__list a:hover {
    color: var(--color-accent);
  }

  .not-found__nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
