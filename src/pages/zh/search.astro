---
import Base from '@/layouts/Base.astro';
import Button from '@/components/ui/Button.astro';
import { SITE_NAME } from '@/data/site';
import { withBase } from '@/utils/url';

// Pagefind outputs into dist/pagefind/, served at <base>/pagefind/.
const pagefindCss = withBase('/pagefind/pagefind-ui.css');
const pagefindJs = withBase('/pagefind/pagefind-ui.js');
const pagefindBundlePath = withBase('/pagefind/');
---

<Base title={`搜尋｜${SITE_NAME}`} noindex={true} lang="zh">
  <link slot="head" href={pagefindCss} rel="stylesheet" />

  <div class="search-page container">
    <header class="search-header">
      <h1>搜尋</h1>
      <p class="search-header__desc">
        輸入關鍵字，使用 Pagefind 全文搜尋本站關於家庭與人生階段的跨文化觀察文章。
      </p>
    </header>

    <div id="search-container"></div>

    <nav class="search-fallback" aria-label="主要入口">
      <h2 class="search-fallback__title">找不到結果？</h2>
      <p class="search-note">請嘗試同義詞或改用較短關鍵字，或直接瀏覽：</p>
      <div class="search-fallback__grid">
        <Button variant="secondary" href={withBase('/zh/')}>首頁</Button>
        <Button variant="secondary" href={withBase('/zh/articles/')}>文章</Button>
        <Button variant="secondary" href={withBase('/zh/about/')}>關於</Button>
      </div>
    </nav>
  </div>

  <script slot="scripts" is:inline src={pagefindJs}></script>
  <script slot="scripts" is:inline define:vars={{ pagefindBundlePath }}>
    window.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q') || params.get('query') || '';

    new PagefindUI({
      element: '#search-container',
      bundlePath: pagefindBundlePath,
      showSubResults: true,
      resetStyles: false,
      translations: {
        placeholder: '搜尋關鍵字（例如：成年、結合、長照、告別）',
      },
      processResult: (result) => result,
    });

    if (initialQuery) {
      const deadline = Date.now() + 3000;
      const interval = setInterval(() => {
        const input = document.querySelector(
          '#search-container input[type="text"], #search-container input[type="search"]'
        );
        if (input instanceof HTMLInputElement) {
          clearInterval(interval);
          input.value = initialQuery;
          input.dispatchEvent(new Event('input', { bubbles: true }));
          input.dispatchEvent(new KeyboardEvent('keyup', { bubbles: true, key: 'Enter' }));
        } else if (Date.now() >= deadline) {
          clearInterval(interval);
        }
      }, 50);
    }
  });
  </script>
</Base>

<style>
  .search-page {
    padding-block: var(--space-page-y);
    max-width: 68ch;
    margin-inline: auto;
  }

  .search-header {
    padding-block: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .search-header h1 {
    font-family: var(--font-sans);
    font-size: var(--text-h1);
    font-weight: 700;
    color: var(--color-ink);
  }

  .search-header__desc {
    color: color-mix(in oklch, var(--color-ink) 72%, transparent);
    line-height: 1.7;
  }

  #search-container {
    padding-block: 1rem 2rem;
  }

  .search-fallback {
    padding-block: 1rem;
  }

  .search-fallback__title {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 0.5rem;
  }

  .search-note {
    color: color-mix(in oklch, var(--color-ink) 65%, transparent);
    font-size: var(--text-meta);
    margin-bottom: 1rem;
  }

  .search-fallback__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
