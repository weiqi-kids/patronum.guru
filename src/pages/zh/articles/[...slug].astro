---
import { getCollection, render } from 'astro:content';
import Article from '@/layouts/Article.astro';
import { classifyArticle, ARTICLE_CATEGORIES } from '@/utils/article-categories';

export async function getStaticPaths() {
  const posts = await getCollection(
    'articles',
    (e) => e.data.lang === 'zh' && !e.data.draft,
  );
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const data = post.data;

const category = classifyArticle(post);
const categoryLabel =
  ARTICLE_CATEGORIES.find((c) => c.slug === category)?.label ?? '文章';

const breadcrumbItems = [
  { label: '首頁', href: '/zh/' },
  { label: '文章', href: '/zh/articles/' },
  { label: categoryLabel, href: '/zh/articles/' },
  { label: data.title },
];

// CJK-aware 閱讀時間估算（約 350 字/分鐘）
const readingTime = Math.max(1, Math.round([...(post.body ?? '')].length / 350));
---

<Article
  title={data.title}
  description={data.description}
  ogSlug={post.id}
  lang={data.lang}
  category={category}
  publishDate={data.generatedDate}
  updatedDate={data.updatedDate}
  readingTime={readingTime}
  breadcrumbItems={breadcrumbItems}
  citationAnswer={data.tldr}
  faq={data.faq}
  sources={data.sources}
  anchorCulture={data.anchorCulture}
  comparedCultures={data.comparedCultures}
  suspectCultures={data.suspectCultures}
  tension={data.tension}
  sensitivityLevel={data.sensitivityLevel}
  patronumVigil={data.patronumVigil}
  writeModel={data.writeModel}
  critiqueModel={data.critiqueModel}
  pipelineVersion={data.pipelineVersion}
  specVersion={data.specVersion}
>
  <Content />
</Article>
